<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aipaint.mapper.DrawingMapper">
    <select id="selectByUserId" parameterType="java.lang.Long" resultType="com.aipaint.entity.Drawing">
        SELECT * FROM drawing WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>
</mapper>